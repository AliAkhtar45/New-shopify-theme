<section class="section-block">
  <div class="container">
    <div class="section-heading">
      <h2>{{ section.settings.title }}</h2>
      <div class="rte">{{ section.settings.description }}</div>
    </div>
    <div class="product-grid">
      {% assign current_collection = section.settings.collection | default: collections.all %}
      {% for product in current_collection.products limit: section.settings.products_to_show %}
        {% render 'product-card', product: product %}
      {% else %}
        <div class="empty-state">Add products to your Shopify store, then choose a collection for this section.</div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Featured products" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Show your best selling supplements here.</p>" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [
    { "name": "Featured collection" }
  ]
}
{% endschema %}
