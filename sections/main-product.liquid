<section class="section-block">
  <div class="container detail-grid">
    <div class="detail-media">
      {% if product.featured_image != blank %}
        {{ product.featured_image | image_url: width: 1200 | image_tag: alt: product.title, class: 'detail-image' }}
      {% else %}
        <div class="product-image-placeholder detail-placeholder"><span>Product Image Placeholder</span></div>
      {% endif %}
    </div>
    <div class="detail-copy">
      {% if product.compare_at_price > product.price %}
        <span class="tag">On Sale</span>
      {% endif %}
      <h1 class="detail-title">{{ product.title }}</h1>
      <div class="detail-intro rte">{{ product.description }}</div>
      <div class="price-row">
        <span class="price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="old-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>
      {% form 'product', product, class: 'product-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% unless product.has_only_default_variant %}
          <label class="field-label" for="variant-{{ section.id }}">Variant</label>
          <select id="variant-{{ section.id }}" name="id" class="field-input">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                {{ variant.title }} - {{ variant.price | money }}
              </option>
            {% endfor %}
          </select>
        {% endunless %}
        <label class="field-label" for="quantity-{{ section.id }}">Quantity</label>
        <input id="quantity-{{ section.id }}" class="field-input" type="number" name="quantity" min="1" value="1">
        <button type="submit" class="button button-primary full">Add to cart</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
