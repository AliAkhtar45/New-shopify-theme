<section class="section-block">
  <div class="container section-heading">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <div class="rte">{{ section.settings.text }}</div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Health Geeks" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A premium Shopify theme starter" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use the theme editor to customize this content.</p>" }
  ],
  "presets": [
    { "name": "Rich text" }
  ]
}
{% endschema %}
