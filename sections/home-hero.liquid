<section class="hero-section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <div class="hero-text rte">{{ section.settings.text }}</div>
      <div class="hero-actions">
        {% if section.settings.primary_label != blank %}
          <a class="button button-primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="button button-secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>
    <div class="hero-stage">
      <div class="hero-banner placeholder-card">
        {% if section.settings.banner_image != blank %}
          {{ section.settings.banner_image | image_url: width: 1400 | image_tag: alt: section.settings.heading, class: 'hero-image' }}
        {% else %}
          <div class="placeholder-label">Banner Placeholder</div>
          <p>Add your promotional banner inside the Shopify theme editor later.</p>
        {% endif %}
      </div>
      <div class="hero-product-card">
        <span class="pill">Best Seller</span>
        {% assign featured_product = section.settings.featured_product %}
        {% if featured_product != blank %}
          {% if featured_product.featured_image != blank %}
            {{ featured_product.featured_image | image_url: width: 900 | image_tag: alt: featured_product.title, class: 'hero-product-image' }}
          {% else %}
            <div class="product-image-placeholder tall"><span>Product Image Placeholder</span></div>
          {% endif %}
          <h2>{{ featured_product.title }}</h2>
          <p>{{ featured_product.description | strip_html | truncatewords: 22 }}</p>
          <div class="price-row">
            <span class="price">{{ featured_product.price | money }}</span>
            {% if featured_product.compare_at_price > featured_product.price %}
              <span class="old-price">{{ featured_product.compare_at_price | money }}</span>
            {% endif %}
          </div>
          <a class="button button-primary" href="{{ featured_product.url }}">View Product</a>
        {% else %}
          <div class="product-image-placeholder tall"><span>Choose a featured product in the theme editor</span></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Health Geeks Store" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Science-backed supplements in a bold dark storefront." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>A premium Shopify homepage for Health Geeks with a darker visual direction.</p>" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop Products" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Contact Store" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "image_picker", "id": "banner_image", "label": "Banner image" },
    { "type": "product", "id": "featured_product", "label": "Featured product" }
  ],
  "presets": [
    { "name": "Home hero" }
  ]
}
{% endschema %}
