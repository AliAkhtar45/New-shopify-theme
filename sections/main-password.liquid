<section class="section-block">
  <div class="container password-shell">
    <div class="password-card">
      <p class="eyebrow">Health Geeks</p>
      <h1 class="detail-title">Store opening soon</h1>
      {% unless shop.password_message == blank %}
        <div class="detail-intro rte">{{ shop.password_message }}</div>
      {% else %}
        <p class="detail-intro">This store is currently password protected. Enter the store password below to continue.</p>
      {% endunless %}

      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <label class="field-label" for="PasswordForm-password">Store password</label>
        <input
          id="PasswordForm-password"
          class="field-input"
          type="password"
          name="password"
          autocomplete="current-password"
        >
        <button class="button button-primary full" type="submit">Enter store</button>
      {% endform %}

      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="prospect, password page">
        <label class="field-label" for="PasswordEmail">Join the waitlist</label>
        <input
          id="PasswordEmail"
          class="field-input"
          type="email"
          name="contact[email]"
          placeholder="you@example.com"
          autocomplete="email"
        >
        <button class="button button-secondary full" type="submit">Notify me</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main password",
  "settings": []
}
{% endschema %}
